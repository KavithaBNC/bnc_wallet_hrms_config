# ===========================================
#  HRMS Production Environment Variables
#  Copy this file to .env and fill in values
# ===========================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hrms_live_v2
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/hrms_live_v2

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production
BASE_URL=https://your-domain.com

# CORS (your frontend domain)
CORS_ORIGIN=https://your-domain.com

# Frontend URL (used in email links)
FRONTEND_URL=https://your-domain.com

# Redis
REDIS_URL=redis://localhost:6379

# Face Service
FACE_SERVICE_URL=http://face-service:8000

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@your-domain.com

# pgAdmin (optional, remove in production)
# PGADMIN_EMAIL=admin@hrms.com
# PGADMIN_PASSWORD=CHANGE_ME

# eSSL Cloud API (optional)
# ESSL_CLOUD_API_URL=https://your-cloud-url.com
# ESSL_CLOUD_API_KEY=your-api-key
