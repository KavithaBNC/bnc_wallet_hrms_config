// Validation Process Rule - for late/early punch correction flow (Apply Event, LOP, etc.)
model ValidationProcessRule {
  id               String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String                     @map("organization_id") @db.Uuid
  displayName      String                     @map("display_name") @db.VarChar(255)
  effectiveDate    DateTime                   @map("effective_date") @db.Date
  priority         Int?
  remarks          String?
  autoCorrect      Boolean                    @default(false) @map("auto_correct")
  correctAfterDays Decimal?                   @map("correct_after_days") @db.Decimal(5, 2)
  primaryAction    Boolean                    @default(false) @map("primary_action")
  hasLimit         Boolean                    @default(false) @map("has_limit")
  validationGrouping String?                  @map("validation_grouping") @db.VarChar(50)
  employeeIds      Json?                      @map("employee_ids")
  shiftIds         Json?                      @map("shift_ids")
  paygroupIds      Json?                      @map("paygroup_ids")
  departmentIds    Json?                      @map("department_ids")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  organization     Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  limits           ValidationRuleLimit[]
  actions          ValidationProcessAction[]

  @@map("validation_process_rules")
}

model ValidationRuleLimit {
  id                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  validationProcessRuleId String             @map("validation_process_rule_id") @db.Uuid
  periodicity           String               @db.VarChar(20)
  maxMinutes            Int?                 @map("max_minutes")
  count                 Int?
  applyAfterEveryCount  Boolean              @default(false) @map("apply_after_every_count")
  deductPriority        String?              @map("deduct_priority") @db.VarChar(50)
  sortOrder             Int                  @default(0) @map("sort_order")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  rule                  ValidationProcessRule @relation(fields: [validationProcessRuleId], references: [id], onDelete: Cascade)

  @@map("validation_rule_limits")
}

model ValidationProcessAction {
  id                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  validationProcessRuleId String             @map("validation_process_rule_id") @db.Uuid
  name                  String               @db.VarChar(100)
  sortOrder             Int                  @default(0) @map("sort_order")
  condition             String               @db.VarChar(50)
  correctionMethod      String               @map("correction_method") @db.VarChar(50)
  attendanceComponentId String?              @map("attendance_component_id") @db.Uuid
  autoApply             String               @map("auto_apply") @db.VarChar(10)
  dayType               String               @map("day_type") @db.VarChar(20)
  days                  String               @db.VarChar(20)
  daysValue             Decimal?             @map("days_value") @db.Decimal(5, 2)
  minMinutes            Int?                 @map("min_minutes")
  maxMinutes            Int?                 @map("max_minutes")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  rule                  ValidationProcessRule @relation(fields: [validationProcessRuleId], references: [id], onDelete: Cascade)
  attendanceComponent   AttendanceComponent? @relation(fields: [attendanceComponentId], references: [id], onDelete: SetNull)

  @@map("validation_process_actions")
}

