
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model Organization {
  id                           String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorCompanyId        Int?                           @unique @map("configurator_company_id")
  name                         String                         @db.VarChar(255)
  legalName                    String?                        @map("legal_name") @db.VarChar(255)
  industry                     String?                        @db.VarChar(100)
  sizeRange                    String?                        @map("size_range") @db.VarChar(20)
  taxId                        String?                        @unique @map("tax_id") @db.VarChar(50)
  registrationNumber           String?                        @map("registration_number") @db.VarChar(100)
  website                      String?                        @db.VarChar(255)
  logoUrl                      String?                        @map("logo_url") @db.VarChar(500)
  address                      Json?
  timezone                     String                         @default("UTC") @db.VarChar(50)
  currency                     String                         @default("USD") @db.VarChar(3)
  fiscalYearStart              DateTime?                      @map("fiscal_year_start") @db.Date
  settings                     Json?
  employeeIdPrefix             String?                        @map("employee_id_prefix") @db.VarChar(20)
  employeeIdNextNumber         Int?                           @map("employee_id_next_number")
  createdAt                    DateTime                       @default(now()) @map("created_at")
  updatedAt                    DateTime                       @updatedAt @map("updated_at")
  approvalWorkflows            ApprovalWorkflow[]
  attendanceComponents         AttendanceComponent[]
  autoCreditSettings           AutoCreditSetting[]
  companies                    Company?
  costCentres                  CostCentre[]
  departments                  Department[]
  employeeSeparations          EmployeeSeparation[]
  employees                    Employee[]
  encashmentCarryForwards      EncashmentCarryForward[]
  entities                     Entity[]
  esopRecords                  Esop[]
  holidays                     Holiday[]
  jobOpenings                  JobOpening[]
  jobPositions                 JobPosition[]                  @relation("OrganizationToJobPosition")
  leavePolicies                LeavePolicy[]
  leaveTypes                   LeaveType[]
  locations                    Location[]
  monthlyAttendanceSummaries   MonthlyAttendanceSummary[]
  monthlyAttendanceLocks       MonthlyAttendanceLock[]
  organizationModules          OrganizationModule[]
  paygroups                    Paygroup[]
  payrollCycles                PayrollCycle[]
  retiredEmployeeCodes         RetiredEmployeeCode[]
  rightsAllocations            RightsAllocation[]
  rolePermissions              RolePermission[]
  ruleSettings                 RuleSetting[]
  salaryStructures             SalaryStructure[]
  salaryTemplates              SalaryTemplate[]
  compOffRequests              CompOffRequest[]
  compOffLedgers               CompOffLedger[]
  shiftAssignmentRules         ShiftAssignmentRule[]
  shifts                       Shift[]
  statutoryCompliances         StatutoryCompliance[]
  subDepartments               SubDepartment[]
  taxConfigurations            TaxConfiguration[]
  transferPromotionEntries     TransferPromotionEntry[]
  transferPromotions           TransferPromotion[]
  users                        User[]
  validationProcessRules       ValidationProcessRule[]
  workflowMappings             WorkflowMapping[]
  attendanceValidationResults  AttendanceValidationResult[]
  postToPayrollMappings        PostToPayrollMapping[]
  validationRevertHistory      ValidationRevertHistory[]
  compounds                   Compound[]
  @@map("organizations")
}

model Company {
  id             String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String            @db.VarChar(255)
  organizationId String?           @unique @map("organization_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  devices        BiometricDevice[]

  @@map("companies")
}

model BiometricDevice {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyId      String          @map("company_id") @db.Uuid
  serialNumber   String          @unique @map("serial_number") @db.VarChar(100)
  name           String?         @db.VarChar(255)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  attendanceLogs AttendanceLog[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model AttendanceLog {
  id             Int              @id @default(autoincrement())
  deviceId       String?          @map("device_id") @db.Uuid
  userId         String           @map("user_id") @db.VarChar(100)
  punchTimestamp DateTime         @map("punch_timestamp")
  status         String           @db.VarChar(20)
  employeeId     String?          @map("employee_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  punchSource    String?          @map("punch_source") @db.VarChar(20)
  device         BiometricDevice? @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee       Employee?        @relation(fields: [employeeId], references: [id])

  @@map("attendance_logs")
}

model AttendancePunch {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  punchTime   DateTime @map("punch_time")
  status      String   @db.VarChar(10)
  punchSource String?  @map("punch_source") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("attendance_punches")
}

model RetiredEmployeeCode {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  code           String       @db.VarChar(50)
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@map("retired_employee_codes")
}

model OrganizationModule {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  resource       String       @db.VarChar(100)
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, resource])
  @@map("organization_modules")
}

model User {
  id                      String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorUserId      Int?                    @unique @map("configurator_user_id")
  email                   String                  @unique @db.VarChar(255)
  passwordHash            String                  @map("password_hash") @db.VarChar(255)
  role                    UserRole
  organizationId          String?                 @map("organization_id") @db.Uuid
  isActive                Boolean                 @default(true) @map("is_active")
  isEmailVerified         Boolean                 @default(false) @map("is_email_verified")
  emailVerificationToken  String?                 @map("email_verification_token") @db.VarChar(255)
  passwordResetToken      String?                 @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires    DateTime?               @map("password_reset_expires")
  lastLoginAt             DateTime?               @map("last_login_at")
  loginAttempts           Int                     @default(0) @map("login_attempts")
  lockedUntil             DateTime?               @map("locked_until")
  twoFactorEnabled        Boolean                 @default(false) @map("two_factor_enabled")
  twoFactorSecret         String?                 @map("two_factor_secret") @db.VarChar(255)
  refreshToken            String?                 @map("refresh_token")
  configuratorAccessToken  String?                @map("configurator_access_token") @db.Text
  configuratorRefreshToken String?               @map("configurator_refresh_token") @db.Text
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  approvedChangeRequests  EmployeeChangeRequest[] @relation("EmployeeChangeRequestApprovals")
  submittedChangeRequests EmployeeChangeRequest[] @relation("EmployeeChangeRequestSubmissions")
  employee                Employee?
  createdInterviews       Interview[]             @relation("InterviewCreator")
  createdJobOpenings      JobOpening[]            @relation("JobOpeningCreator")
  createdOffers           Offer[]                 @relation("OfferCreator")
  organization            Organization?           @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model Permission {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String           @unique @db.VarChar(100)
  resource        String           @db.VarChar(100)
  action          String           @db.VarChar(50)
  description     String?
  module          String?          @db.VarChar(100)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  role           UserRole
  permissionId   String        @map("permission_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permission     Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId, organizationId])
  @@map("role_permissions")
}

model Department {
  id                        String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorDepartmentId  Int?                  @map("configurator_department_id")
  organizationId            String                @map("organization_id") @db.Uuid
  name                      String                @db.VarChar(255)
  code                      String?               @unique @db.VarChar(50)
  description          String?
  parentDepartmentId   String?               @map("parent_department_id") @db.Uuid
  managerId            String?               @map("manager_id") @db.Uuid
  costCenter           String?               @map("cost_center") @db.VarChar(50)
  location             String?               @db.VarChar(255)
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  autoCreditSettings   AutoCreditSetting[]
  manager              Employee?             @relation("DepartmentManager", fields: [managerId], references: [id])
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment     Department?           @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments       Department[]          @relation("DepartmentHierarchy")
  employees            Employee[]            @relation("EmployeeDepartment")
  jobOpenings          JobOpening[]
  jobPositions         JobPosition[]
  ruleSettings         RuleSetting[]
  shiftAssignmentRules ShiftAssignmentRule[]
  workflowMappings     WorkflowMapping[]

  @@map("departments")
}

model SubDepartment {
  id                             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorSubDepartmentId    Int?         @map("configurator_sub_department_id")
  organizationId                 String       @map("organization_id") @db.Uuid
  name                           String       @db.VarChar(255)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("sub_departments")
}

model JobPosition {
  id                           String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId               String                   @map("organization_id") @db.Uuid
  title                        String                   @db.VarChar(255)
  code                         String?                  @unique @db.VarChar(50)
  departmentId                 String?                  @map("department_id") @db.Uuid
  level                        PositionLevel?
  employmentType               EmploymentType?          @map("employment_type")
  description                  String?
  requirements                 Json?
  responsibilities             Json?
  salaryRangeMin               Decimal?                 @map("salary_range_min") @db.Decimal(15, 2)
  salaryRangeMax               Decimal?                 @map("salary_range_max") @db.Decimal(15, 2)
  isActive                     Boolean                  @default(true) @map("is_active")
  createdAt                    DateTime                 @default(now()) @map("created_at")
  updatedAt                    DateTime                 @updatedAt @map("updated_at")
  employees                    Employee[]
  jobOpenings                  JobOpening[]
  department                   Department?              @relation(fields: [departmentId], references: [id])
  organization                 Organization             @relation("OrganizationToJobPosition", fields: [organizationId], references: [id], onDelete: Cascade)
  transferPromotionEntriesFrom TransferPromotionEntry[] @relation("EntryPromotionFrom")
  transferPromotionEntriesTo   TransferPromotionEntry[] @relation("EntryPromotionTo")

  @@map("job_positions")
}

model Paygroup {
  id                       String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId           String                    @map("organization_id") @db.Uuid
  name                     String                    @db.VarChar(255)
  code                     String?                   @unique @db.VarChar(50)
  isActive                 Boolean                   @default(true) @map("is_active")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  autoCreditSettings       AutoCreditSetting[]
  employees                Employee[]
  organization             Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleSettings             RuleSetting[]
  shiftAssignmentRules     ShiftAssignmentRule[]
  transferPromotionEntries TransferPromotionEntry[]
  transferPromotions       TransferPromotion[]
  workflowMappings         WorkflowMapping[]
  componentRules           PaygroupComponentRule[]

  @@unique([organizationId, name])
  @@map("paygroups")
}

model Entity {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  code           String?      @db.VarChar(50)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations      Location[]

  @@unique([organizationId, name])
  @@map("entities")
}

model Location {
  id                     String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorBranchId   Int?         @map("configurator_branch_id")
  organizationId         String       @map("organization_id") @db.Uuid
  entityId               String       @map("entity_id") @db.Uuid
  name                   String       @db.VarChar(255)
  code                   String?      @db.VarChar(50)
  isActive               Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  employees      Employee[]
  entity         Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([entityId, name])
  @@map("locations")
}

model CostCentre {
  id                          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  configuratorCostCentreId    Int?         @map("configurator_cost_centre_id")
  organizationId              String       @map("organization_id") @db.Uuid
  name                        String       @db.VarChar(255)
  code                        String?      @unique @db.VarChar(50)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees      Employee[]

  @@map("cost_centres")
}

model Employee {
  id                           String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId               String                         @map("organization_id") @db.Uuid
  employeeCode                 String                         @unique @map("employee_code") @db.VarChar(50)
  userId                       String                         @unique @map("user_id") @db.Uuid
  configuratorUserId           Int?                           @unique @map("configurator_user_id")
  departmentConfiguratorId     Int?                           @map("department_configurator_id")
  subDepartmentConfiguratorId  Int?                           @map("sub_department_configurator_id")
  costCentreConfiguratorId     Int?                           @map("cost_centre_configurator_id")
  branchConfiguratorId         Int?                           @map("branch_configurator_id")
  paygroupId                   String?                        @map("paygroup_id") @db.Uuid
  firstName                    String                         @map("first_name") @db.VarChar(100)
  middleName                   String?                        @map("middle_name") @db.VarChar(100)
  lastName                     String                         @map("last_name") @db.VarChar(100)
  email                        String                         @unique @db.VarChar(255)
  personalEmail                String?                        @map("personal_email") @db.VarChar(255)
  phone                        String?                        @db.VarChar(20)
  officialEmail                String?                        @map("official_email") @db.VarChar(255)
  officialMobile               String?                        @map("official_mobile") @db.VarChar(20)
  dateOfBirth                  DateTime?                      @map("date_of_birth") @db.Date
  gender                       Gender?
  maritalStatus                MaritalStatus?                 @map("marital_status")
  nationality                  String?                        @db.VarChar(100)
  profilePictureUrl            String?                        @map("profile_picture_url") @db.VarChar(500)
  departmentId                 String?                        @map("department_id") @db.Uuid
  positionId                   String?                        @map("position_id") @db.Uuid
  reportingManagerId           String?                        @map("reporting_manager_id") @db.Uuid
  shiftId                      String?                        @map("shift_id") @db.Uuid
  workLocation                 String?                        @map("work_location") @db.VarChar(255)
  locationId                   String?                        @map("location_id") @db.Uuid
  costCentreId                 String?                        @map("cost_centre_id") @db.Uuid
  grade                        String?                        @db.VarChar(50)
  placeOfTaxDeduction          PlaceOfTaxDeduction?           @map("place_of_tax_deduction")
  jobResponsibility            String?                        @map("job_responsibility")
  employmentType               EmploymentType?                @map("employment_type")
  employeeStatus               EmployeeStatus                 @default(ACTIVE) @map("employee_status")
  dateOfJoining                DateTime                       @map("date_of_joining") @db.Date
  probationEndDate             DateTime?                      @map("probation_end_date") @db.Date
  confirmationDate             DateTime?                      @map("confirmation_date") @db.Date
  dateOfLeaving                DateTime?                      @map("date_of_leaving") @db.Date
  terminationReason            String?                        @map("termination_reason")
  address                      Json?
  emergencyContacts            Json?                          @map("emergency_contacts")
  bankDetails                  Json?                          @map("bank_details")
  taxInformation               Json?                          @map("tax_information")
  documents                    Json?
  createdAt                    DateTime                       @default(now()) @map("created_at")
  updatedAt                    DateTime                       @updatedAt @map("updated_at")
  deletedAt                    DateTime?                      @map("deleted_at")
  entityId                     String?                        @map("entity_id") @db.Uuid
  profileExtensions            Json?                          @map("profile_extensions")
  is_rejoin                    Boolean                        @default(false) @map("is_rejoin")
  previousEmployeeId           String?                        @map("previous_employee_id") @db.Uuid
  previousEmployeeCode         String?                        @map("previous_employee_code") @db.VarChar(50)
  faceEncoding                 Json?                          @map("face_encoding")
  assignedApplications         Application[]                  @relation("ApplicationRecruiter")
  attendanceLogs               AttendanceLog[]
  attendancePunches            AttendancePunch[]
  attendanceRecords            AttendanceRecord[]
  attendanceRegularizations    AttendanceRegularization[]
  referredCandidates           Candidate[]                    @relation("CandidateReferrer")
  managedDepartments           Department[]                   @relation("DepartmentManager")
  bankAccounts                 EmployeeBankAccount[]
  changeRequests               EmployeeChangeRequest[]        @relation("EmployeeChangeRequests")
  leaveBalances                EmployeeLeaveBalance[]
  salaries                     EmployeeSalary[]
  separations                  EmployeeSeparation[]
  costCentre                   CostCentre?                    @relation(fields: [costCentreId], references: [id])
  department                   Department?                    @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  entity                       Entity?                        @relation(fields: [entityId], references: [id], onDelete: SetNull)
  location                     Location?                      @relation(fields: [locationId], references: [id])
  organization                 Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paygroup                     Paygroup?                      @relation(fields: [paygroupId], references: [id])
  position                     JobPosition?                   @relation(fields: [positionId], references: [id])
  previousEmployee             Employee?                      @relation("EmployeeRejoin", fields: [previousEmployeeId], references: [id])
  rejoinedEmployee             Employee[]                     @relation("EmployeeRejoin")
  reportingManager             Employee?                      @relation("EmployeeHierarchy", fields: [reportingManagerId], references: [id])
  subordinates                 Employee[]                     @relation("EmployeeHierarchy")
  shift                        Shift?                         @relation(fields: [shiftId], references: [id])
  user                         User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  encashmentCarryForwards      EncashmentCarryForward[]
  esopRecords                  Esop[]
  hiringManagerJobs            JobOpening[]                   @relation("HiringManager")
  leaveRequests                LeaveRequest[]
  leaveRequestsToApprove       LeaveRequest[]                 @relation("LeaveRequestApprover")
  compOffRequests              CompOffRequest[]
  compOffLedgers               CompOffLedger[]
  monthlyAttendanceSummaries   MonthlyAttendanceSummary[]
  payslips                     Payslip[]
  transferPromotionEntries     TransferPromotionEntry[]
  transferPromotions           TransferPromotion[]
  attendanceValidationResults  AttendanceValidationResult[]

  @@map("employees")
}

model TransferPromotion {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  employeeId          String       @map("employee_id") @db.Uuid
  paygroupId          String?      @map("paygroup_id") @db.Uuid
  effectiveDate       DateTime     @map("effective_date") @db.Date
  appliedFrom         String       @map("applied_from") @db.VarChar(50)
  isIncrement         Boolean      @default(true) @map("is_increment")
  incrementFrom       DateTime?    @map("increment_from") @db.Date
  afterLOP            Decimal      @default(0) @map("after_lop") @db.Decimal(12, 2)
  beforeLOP           Decimal      @default(0) @map("before_lop") @db.Decimal(12, 2)
  incrementComponents Json?        @map("increment_components")
  notes               String?      @db.VarChar(500)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  employee            Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paygroup            Paygroup?    @relation(fields: [paygroupId], references: [id])

  @@map("transfer_promotions")
}

model TransferPromotionEntry {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  employeeId         String       @map("employee_id") @db.Uuid
  paygroupId         String?      @map("paygroup_id") @db.Uuid
  effectiveDate      DateTime     @map("effective_date") @db.Date
  remarks            String?      @db.VarChar(500)
  promotionEnabled   Boolean      @default(false) @map("promotion_enabled")
  promotionFromId    String?      @map("promotion_from_id") @db.Uuid
  promotionToId      String?      @map("promotion_to_id") @db.Uuid
  transferComponents Json?        @map("transfer_components")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  employee           Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paygroup           Paygroup?    @relation(fields: [paygroupId], references: [id])
  promotionFrom      JobPosition? @relation("EntryPromotionFrom", fields: [promotionFromId], references: [id])
  promotionTo        JobPosition? @relation("EntryPromotionTo", fields: [promotionToId], references: [id])

  @@map("transfer_promotion_entry")
}

model Esop {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  employeeId       String       @map("employee_id") @db.Uuid
  financialYear    String       @map("financial_year") @db.VarChar(20)
  noOfEsop         Int          @default(0) @map("no_of_esop")
  dateOfAllocation DateTime?    @map("date_of_allocation") @db.Date
  visted           String?      @db.VarChar(255)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("esop")
}

model AttendanceRecord {
  id              String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId      String                     @map("employee_id") @db.Uuid
  shiftId         String?                    @map("shift_id") @db.Uuid
  date            DateTime                   @db.Date
  checkIn         DateTime?                  @map("check_in")
  checkOut        DateTime?                  @map("check_out")
  totalHours      Decimal?                   @map("total_hours") @db.Decimal(5, 2)
  breakHours      Decimal?                   @map("break_hours") @db.Decimal(5, 2)
