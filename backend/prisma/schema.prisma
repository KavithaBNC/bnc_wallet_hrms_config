// Employee Separation (Payroll sub-module)
model EmployeeSeparation {
  id                    String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId            String         @map("employee_id") @db.Uuid
  organizationId       String         @map("organization_id") @db.Uuid
  resignationApplyDate DateTime       @map("resignation_apply_date") @db.Date
  noticePeriod         Int            @map("notice_period") // days
  noticePeriodReason   String?        @map("notice_period_reason") @db.VarChar(255)
  relievingDate        DateTime       @map("relieving_date") @db.Date
  reasonOfLeaving      String?        @map("reason_of_leaving") @db.VarChar(255)
  separationType       SeparationType @map("separation_type")
  remarks              String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("employee_separations")
  @@index([organizationId])
  @@index([employeeId])
}

enum SeparationType {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
  ABSONDING
  OTHER

  @@map("separation_type")
}

