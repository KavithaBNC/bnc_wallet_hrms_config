  aiRecommendations Json?    @map("ai_recommendations")

  overallRating   Decimal? @map("overall_rating") @db.Decimal(3, 2)
  recruiterRating Decimal? @map("recruiter_rating") @db.Decimal(3, 2)
  recruiterNotes  String?  @map("recruiter_notes") @db.Text

  rejectionReason String?   @map("rejection_reason") @db.Text
  rejectionDate   DateTime? @map("rejection_date")
  withdrawnReason String?   @map("withdrawn_reason") @db.Text
  withdrawnDate   DateTime? @map("withdrawn_date")

  assignedTo String? @map("assigned_to") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  jobOpening        JobOpening                @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  candidate         Candidate                 @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assignedRecruiter Employee?                 @relation("ApplicationRecruiter", fields: [assignedTo], references: [id], onDelete: SetNull)
  applicationStages ApplicationStageHistory[]
  interviews        Interview[]
  offers            Offer[]

  @@unique([jobOpeningId, candidateId])
  @@map("applications")
}

enum ApplicationStageEnum {
  NEW
  SCREENING
  PHONE_SCREEN
  ASSESSMENT
  INTERVIEW_1
  INTERVIEW_2
  INTERVIEW_3
  HR_ROUND
  OFFER
  HIRED
  REJECTED
  WITHDRAWN

  @@map("application_stage")
}

enum ApplicationStatus {
  ACTIVE
  ON_HOLD
  REJECTED
  HIRED
  WITHDRAWN

  @@map("application_status")
}

model ApplicationStageHistory {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  stage         String      @db.VarChar(50)
  status        StageStatus
  startedAt     DateTime?   @map("started_at")
  completedAt   DateTime?   @map("completed_at")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_stages")
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED

  @@map("stage_status")
}

model Interview {
  id            String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  applicationId String @map("application_id") @db.Uuid
  jobOpeningId  String @map("job_opening_id") @db.Uuid
  candidateId   String @map("candidate_id") @db.Uuid

  round Int
  type  InterviewType?
  title String         @db.VarChar(255)

  scheduledAt     DateTime? @map("scheduled_at")
  durationMinutes Int?      @map("duration_minutes")
  meetingLink     String?   @map("meeting_link") @db.VarChar(500)
  location        String?   @db.VarChar(255)

  interviewers   Json? // Array of employee IDs
  interviewPanel Json? @map("interview_panel")

  status InterviewStatus @default(SCHEDULED)

  feedback       Json? // [{interviewer_id, rating, comments, skills_assessed}]
  overallRating  Decimal?                 @map("overall_rating") @db.Decimal(3, 2)
  recommendation InterviewRecommendation?

  cancellationReason String? @map("cancellation_reason") @db.Text
  rescheduleCount    Int     @default(0) @map("reschedule_count")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobOpening  JobOpening  @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  creator     User?       @relation("InterviewCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("interviews")
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
  TECHNICAL
  HR
  CULTURAL_FIT
  PANEL

  @@map("interview_type")
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("interview_status")
}

enum InterviewRecommendation {
  STRONG_YES
  YES
  MAYBE
  NO
  STRONG_NO

  @@map("interview_recommendation")
}

model Offer {
  id            String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  applicationId String @map("application_id") @db.Uuid
  candidateId   String @map("candidate_id") @db.Uuid
  jobOpeningId  String @map("job_opening_id") @db.Uuid

  offerLetterUrl       String?  @map("offer_letter_url") @db.VarChar(500)
  offeredPosition      String   @map("offered_position") @db.VarChar(255)
  offeredSalary        Decimal  @map("offered_salary") @db.Decimal(15, 2)
  salaryComponents     Json?    @map("salary_components")
  benefits             Json?
  joiningBonus         Decimal? @map("joining_bonus") @db.Decimal(15, 2)
  relocationAssistance Decimal? @map("relocation_assistance") @db.Decimal(15, 2)

  offeredDate         DateTime  @map("offered_date") @db.Date
  validUntil          DateTime  @map("valid_until") @db.Date
  expectedJoiningDate DateTime? @map("expected_joining_date") @db.Date

  status OfferStatus @default(DRAFT)

  acceptedDate     DateTime? @map("accepted_date")
  rejectedDate     DateTime? @map("rejected_date")
  rejectionReason  String?   @map("rejection_reason") @db.Text
  negotiationNotes String?   @map("negotiation_notes") @db.Text

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening  JobOpening  @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  creator     User?       @relation("OfferCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("offers")
}

enum OfferStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  NEGOTIATING
  EXPIRED

  @@map("offer_status")
}
