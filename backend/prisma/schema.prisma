// This is your Prisma schema file for HRMS Portal 2026
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp")]
}

// ============================================================================
// CORE HR MODULE - Phase 1 & 2
// ============================================================================

model Organization {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String    @db.VarChar(255)
  legalName          String?   @map("legal_name") @db.VarChar(255)
  industry           String?   @db.VarChar(100)
  sizeRange          String?   @map("size_range") @db.VarChar(20)
  taxId              String?   @unique @map("tax_id") @db.VarChar(50)
  registrationNumber String?   @map("registration_number") @db.VarChar(100)
  website            String?   @db.VarChar(255)
  logoUrl            String?   @map("logo_url") @db.VarChar(500)
  address            Json?
  timezone           String    @default("UTC") @db.VarChar(50)
  currency           String    @default("USD") @db.VarChar(3)
  fiscalYearStart    DateTime? @map("fiscal_year_start") @db.Date
  settings             Json?
  employeeIdPrefix     String?  @map("employee_id_prefix") @db.VarChar(20)
  employeeIdNextNumber Int?     @map("employee_id_next_number") @db.Integer
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  users                User[]
  departments          Department[]
  subDepartments       SubDepartment[]
  jobPositions         JobPosition[]         @relation("OrganizationToJobPosition")
  paygroups            Paygroup[]
  entities             Entity[]
  locations            Location[]
  costCentres          CostCentre[]
  employees            Employee[]
  leaveTypes           LeaveType[]
  holidays             Holiday[]
  leavePolicies        LeavePolicy[]
  shifts               Shift[]
  rolePermissions      RolePermission[]
  salaryStructures     SalaryStructure[]
  salaryTemplates       SalaryTemplate[]
  payrollCycles        PayrollCycle[]
  taxConfigurations    TaxConfiguration[]
  statutoryCompliances StatutoryCompliance[]
  jobOpenings          JobOpening[]
  organizationModules  OrganizationModule[]
  employeeSeparations  EmployeeSeparation[]

  @@map("organizations")
}

// Per-organization enabled modules (SAP-style: Super Admin assigns which modules each org gets)
model OrganizationModule {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  resource       String   @db.VarChar(100) // e.g. "employees", "departments", "permissions"
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, resource])
  @@map("organization_modules")
}

model User {
  id                     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                  String    @unique @db.VarChar(255)
  passwordHash           String    @map("password_hash") @db.VarChar(255)
  role                   UserRole
  organizationId         String?   @map("organization_id") @db.Uuid
  isActive               Boolean   @default(true) @map("is_active")
  isEmailVerified        Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken String?   @map("email_verification_token") @db.VarChar(255)
  passwordResetToken     String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires   DateTime? @map("password_reset_expires")
  lastLoginAt            DateTime? @map("last_login_at")
  loginAttempts          Int       @default(0) @map("login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  twoFactorEnabled       Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret        String?   @map("two_factor_secret") @db.VarChar(255)
  refreshToken           String?   @map("refresh_token") @db.Text
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // Relations
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  employee           Employee?
  // ATS Relations
  createdJobOpenings JobOpening[]  @relation("JobOpeningCreator")
  createdInterviews  Interview[]   @relation("InterviewCreator")
  createdOffers      Offer[]       @relation("OfferCreator")
  // Employee Master Approval
  submittedChangeRequests EmployeeChangeRequest[] @relation("EmployeeChangeRequestSubmissions")
  approvedChangeRequests  EmployeeChangeRequest[] @relation("EmployeeChangeRequestApprovals")

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE

  @@map("user_role")
}

// ============================================================================
// ROLE & PERMISSION MANAGEMENT
// ============================================================================

model Permission {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(100) // e.g., "employees", "departments", "attendance"
  action      String   @db.VarChar(50) // e.g., "create", "read", "update", "delete", "approve"
  description String?  @db.Text
  module      String?  @db.VarChar(100) // e.g., "Employee Management", "Leave Management"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  role           UserRole
  permissionId   String   @map("permission_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid // null = system-wide, set = org-specific
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId, organizationId])
  @@map("role_permissions")
}

model Department {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  name               String   @db.VarChar(255)
  code               String?  @unique @db.VarChar(50)
  description        String?  @db.Text
  parentDepartmentId String?  @map("parent_department_id") @db.Uuid
  managerId          String?  @map("manager_id") @db.Uuid
  costCenter         String?  @map("cost_center") @db.VarChar(50)
  location           String?  @db.VarChar(255)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment Department?   @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments   Department[]  @relation("DepartmentHierarchy")
  manager          Employee?     @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees        Employee[]    @relation("EmployeeDepartment")
  jobPositions     JobPosition[]
  jobOpenings      JobOpening[]

  @@map("departments")
}

model SubDepartment {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("sub_departments")
}

model JobPosition {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String          @map("organization_id") @db.Uuid
  title            String          @db.VarChar(255)
  code             String?         @unique @db.VarChar(50)
  departmentId     String?         @map("department_id") @db.Uuid
  level            PositionLevel?
  employmentType   EmploymentType? @map("employment_type")
  description      String?         @db.Text
  requirements     Json?
  responsibilities Json?
  salaryRangeMin   Decimal?        @map("salary_range_min") @db.Decimal(15, 2)
  salaryRangeMax   Decimal?        @map("salary_range_max") @db.Decimal(15, 2)
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation("OrganizationToJobPosition", fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees    Employee[]
  jobOpenings  JobOpening[]

  @@map("job_positions")
}

model Paygroup {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  code           String?  @unique @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, name])
  @@map("paygroups")
}

model Entity {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  code           String?  @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations    Location[]
  employees    Employee[]

  @@unique([organizationId, name])
  @@map("entities")
}

model Location {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  entityId       String   @map("entity_id") @db.Uuid
  name           String   @db.VarChar(255)
  code           String?  @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entity       Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([entityId, name])
  @@map("locations")
}

model CostCentre {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  code           String?  @unique @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@map("cost_centres")
}

enum PositionLevel {
  ENTRY
  JUNIOR
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  VP
  C_LEVEL

  @@map("position_level")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN

  @@map("employment_type")
}

model Employee {
  id             String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  employeeCode   String @unique @map("employee_code") @db.VarChar(50)
  userId         String @unique @map("user_id") @db.Uuid

  // Paygroup (from Associate create flow)
  paygroupId String? @map("paygroup_id") @db.Uuid

  // Personal Information
  firstName         String         @map("first_name") @db.VarChar(100)
  middleName        String?        @map("middle_name") @db.VarChar(100)
  lastName          String         @map("last_name") @db.VarChar(100)
  email             String         @unique @db.VarChar(255)
  personalEmail     String?        @map("personal_email") @db.VarChar(255)
  phone             String?        @db.VarChar(20)
  officialEmail     String?        @map("official_email") @db.VarChar(255)
  officialMobile    String?        @map("official_mobile") @db.VarChar(20)
  dateOfBirth       DateTime?      @map("date_of_birth") @db.Date
  gender            Gender?
  maritalStatus     MaritalStatus? @map("marital_status")
  nationality       String?        @db.VarChar(100)
  profilePictureUrl String?        @map("profile_picture_url") @db.VarChar(500)

  // Employment Information
  departmentId          String?         @map("department_id") @db.Uuid
  positionId            String?         @map("position_id") @db.Uuid
  reportingManagerId    String?         @map("reporting_manager_id") @db.Uuid
  shiftId              String?         @map("shift_id") @db.Uuid
  workLocation         String?         @map("work_location") @db.VarChar(255)
  entityId             String?         @map("entity_id") @db.Uuid
  locationId           String?         @map("location_id") @db.Uuid
  costCentreId         String?         @map("cost_centre_id") @db.Uuid
  grade                String?         @db.VarChar(50)
  placeOfTaxDeduction  PlaceOfTaxDeduction? @map("place_of_tax_deduction")
  jobResponsibility    String?         @map("job_responsibility") @db.Text
  employmentType       EmploymentType? @map("employment_type")
  employeeStatus       EmployeeStatus  @default(ACTIVE) @map("employee_status")

  // Dates
  dateOfJoining     DateTime  @map("date_of_joining") @db.Date
  probationEndDate  DateTime? @map("probation_end_date") @db.Date
  confirmationDate  DateTime? @map("confirmation_date") @db.Date
  dateOfLeaving     DateTime? @map("date_of_leaving") @db.Date
  terminationReason String?   @map("termination_reason") @db.Text

  // Additional Information (JSONB)
  address            Json?
  emergencyContacts  Json? @map("emergency_contacts")
  bankDetails        Json? @map("bank_details")
  taxInformation     Json? @map("tax_information")
  documents          Json?
  profileExtensions  Json? @map("profile_extensions") // academicQualifications, previousEmployments, familyMembers

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paygroup                  Paygroup?                  @relation(fields: [paygroupId], references: [id], onDelete: SetNull)
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department                Department?                @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  position                  JobPosition?               @relation(fields: [positionId], references: [id], onDelete: SetNull)
  reportingManager          Employee?                  @relation("EmployeeHierarchy", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  entity                    Entity?                    @relation(fields: [entityId], references: [id], onDelete: SetNull)
  location                  Location?                  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  costCentre                CostCentre?                @relation(fields: [costCentreId], references: [id], onDelete: SetNull)
  shift                     Shift?                     @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  subordinates              Employee[]                 @relation("EmployeeHierarchy")
  managedDepartments        Department[]               @relation("DepartmentManager")
  attendanceRecords         AttendanceRecord[]
  leaveRequests             LeaveRequest[]
  leaveBalances             EmployeeLeaveBalance[]
  attendanceRegularizations AttendanceRegularization[]
  bankAccounts              EmployeeBankAccount[]
  salaries                  EmployeeSalary[]
  payslips                  Payslip[]
  // ATS Relations
  hiringManagerJobs         JobOpening[]               @relation("HiringManager")
  referredCandidates        Candidate[]                @relation("CandidateReferrer")
  assignedApplications      Application[]              @relation("ApplicationRecruiter")
  changeRequests            EmployeeChangeRequest[]     @relation("EmployeeChangeRequests")
  separations               EmployeeSeparation[]

  @@map("employees")
}

// Employee Master Approval: pending changes submitted by employee (or approval-required role)
model EmployeeChangeRequest {
  id              String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId      String                    @map("employee_id") @db.Uuid
  submittedById   String                    @map("submitted_by_id") @db.Uuid
  organizationId  String                    @map("organization_id") @db.Uuid
  status          EmployeeChangeRequestStatus @default(PENDING)
  existingData    Json                      @map("existing_data")   // snapshot of employee data before change
  requestedData   Json                      @map("requested_data") // form payload to apply on approve
  submittedAt     DateTime                  @default(now()) @map("submitted_at")
  approvedById    String?                   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?                 @map("approved_at")
  rejectionReason String?                   @map("rejection_reason") @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  employee     Employee @relation("EmployeeChangeRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  submittedBy  User     @relation("EmployeeChangeRequestSubmissions", fields: [submittedById], references: [id], onDelete: Cascade)
  approvedBy   User?    @relation("EmployeeChangeRequestApprovals", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("employee_change_requests")
}

enum EmployeeChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("employee_change_request_status")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY

  @@map("gender")
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED

  @@map("marital_status")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED

  @@map("employee_status")
}

enum PlaceOfTaxDeduction {
  METRO
  NON_METRO

  @@map("place_of_tax_deduction")
}

// ============================================================================
// ATTENDANCE & LEAVE MODULE - Phase 3
// ============================================================================

model AttendanceRecord {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId    String            @map("employee_id") @db.Uuid
  shiftId       String?           @map("shift_id") @db.Uuid
  date          DateTime          @db.Date
  checkIn       DateTime?         @map("check_in")
  checkOut      DateTime?         @map("check_out")
  totalHours    Decimal?          @map("total_hours") @db.Decimal(5, 2)
  breakHours    Decimal?          @map("break_hours") @db.Decimal(5, 2)
  workHours     Decimal?          @map("work_hours") @db.Decimal(5, 2)
  overtimeHours Decimal?          @map("overtime_hours") @db.Decimal(5, 2)
  status        AttendanceStatus?
  location      Json?
  checkInMethod CheckInMethod?    @map("check_in_method")
  notes         String?           @db.Text
  approvedBy    String?           @map("approved_by") @db.Uuid
  approvedAt    DateTime?         @map("approved_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  // Relations
  employee        Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift           Shift?                     @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  regularizations AttendanceRegularization[]

  @@unique([employeeId, date])
  @@map("attendance_records")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKEND

  @@map("attendance_status")
}

enum CheckInMethod {
  MANUAL
  BIOMETRIC
  WEB
  MOBILE
  GEOFENCE

  @@map("check_in_method")
}

// ============================================================================
// SHIFT MANAGEMENT
// ============================================================================

model Shift {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  name              String   @db.VarChar(100)
  code              String?  @unique @db.VarChar(50)
  description       String?  @db.Text
  startTime         String   @map("start_time") @db.VarChar(10) // HH:mm format
  endTime           String   @map("end_time") @db.VarChar(10) // HH:mm format
  breakDuration     Int?     @map("break_duration") // minutes
  workHours         Decimal? @map("work_hours") @db.Decimal(5, 2)
  isFlexible        Boolean  @default(false) @map("is_flexible")
  gracePeriod       Int?     @map("grace_period") // minutes for late check-in
  earlyLeaveAllowed Boolean  @default(false) @map("early_leave_allowed")
  overtimeEnabled   Boolean  @default(true) @map("overtime_enabled")
  overtimeThreshold Decimal? @map("overtime_threshold") @db.Decimal(5, 2) // hours
  geofenceEnabled   Boolean  @default(false) @map("geofence_enabled")
  geofenceRadius    Decimal? @map("geofence_radius") @db.Decimal(10, 2) // meters
  geofenceLocation  Json?    @map("geofence_location") // {lat, lng, address}
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees         Employee[]
  attendanceRecords AttendanceRecord[]

  @@map("shifts")
}

// ============================================================================
// ATTENDANCE REGULARIZATION
// ============================================================================

model AttendanceRegularization {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId          String               @map("employee_id") @db.Uuid
  attendanceRecordId  String?              @map("attendance_record_id") @db.Uuid
  date                DateTime             @db.Date
  requestedCheckIn    DateTime?            @map("requested_check_in")
  requestedCheckOut   DateTime?            @map("requested_check_out")
  reason              String               @db.Text
  supportingDocuments Json?                @map("supporting_documents")
  status              RegularizationStatus @default(PENDING)
  appliedOn           DateTime             @default(now()) @map("applied_on")
  reviewedBy          String?              @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?            @map("reviewed_at")
  reviewComments      String?              @map("review_comments") @db.Text
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  // Relations
  employee         Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceRecord AttendanceRecord? @relation(fields: [attendanceRecordId], references: [id], onDelete: SetNull)

  @@map("attendance_regularizations")
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@map("regularization_status")
}

model LeaveType {
  id                 String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  name               String       @db.VarChar(100)
  code               String?      @unique @db.VarChar(50)
  description        String?      @db.Text
  isPaid             Boolean      @default(true) @map("is_paid")
  defaultDaysPerYear Decimal?     @map("default_days_per_year") @db.Decimal(5, 2)
  maxCarryForward    Decimal?     @map("max_carry_forward") @db.Decimal(5, 2)
  maxConsecutiveDays Int?         @map("max_consecutive_days")
  requiresDocument   Boolean      @default(false) @map("requires_document")
  requiresApproval   Boolean      @default(true) @map("requires_approval")
  canBeNegative      Boolean      @default(false) @map("can_be_negative")
  accrualType        AccrualType? @map("accrual_type")
  colorCode          String?      @map("color_code") @db.VarChar(20)
  isActive           Boolean      @default(true) @map("is_active")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Relations
  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]
  leaveBalances EmployeeLeaveBalance[]
  leavePolicies LeavePolicy[]

  @@map("leave_types")
}

enum AccrualType {
  MONTHLY
  QUARTERLY
  ANNUALLY
  NONE

  @@map("accrual_type")
}

model EmployeeLeaveBalance {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  leaveTypeId    String   @map("leave_type_id") @db.Uuid
  year           Int
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(5, 2)
