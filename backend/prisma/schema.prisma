model Payslip {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  payrollCycleId   String   @map("payroll_cycle_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  employeeSalaryId String?  @map("employee_salary_id") @db.Uuid
  periodStart      DateTime @map("period_start") @db.Date
  periodEnd        DateTime @map("period_end") @db.Date
  paymentDate      DateTime @map("payment_date") @db.Date

  // Salary Components
  basicSalary     Decimal? @map("basic_salary") @db.Decimal(15, 2)
  earnings        Json? // [{component, amount, is_taxable}]
  deductions      Json? // [{component, amount, type}]
  grossSalary     Decimal  @map("gross_salary") @db.Decimal(15, 2)
  totalDeductions Decimal? @map("total_deductions") @db.Decimal(15, 2)
  netSalary       Decimal  @map("net_salary") @db.Decimal(15, 2)

  // Attendance
  attendanceDays Decimal? @map("attendance_days") @db.Decimal(5, 2)
  paidDays       Decimal? @map("paid_days") @db.Decimal(5, 2)
  unpaidDays     Decimal? @map("unpaid_days") @db.Decimal(5, 2)
  overtimeHours  Decimal? @map("overtime_hours") @db.Decimal(8, 2)

  // Tax and Statutory
  taxDetails          Json? @map("tax_details")
  statutoryDeductions Json? @map("statutory_deductions")

  // YTD Totals (Year-to-Date)
  ytdGrossSalary      Decimal? @map("ytd_gross_salary") @db.Decimal(15, 2)
  ytdDeductions       Decimal? @map("ytd_deductions") @db.Decimal(15, 2)
  ytdNetSalary        Decimal? @map("ytd_net_salary") @db.Decimal(15, 2)
  ytdTaxPaid          Decimal? @map("ytd_tax_paid") @db.Decimal(15, 2)

  // Payment
  status           PayslipStatus  @default(DRAFT)
  pdfUrl           String?        @map("pdf_url") @db.VarChar(500)
  paymentMethod    PaymentMethod? @map("payment_method")
  paymentReference String?        @map("payment_reference") @db.VarChar(100)
  paymentStatus    PaymentStatus? @map("payment_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  payrollCycle   PayrollCycle    @relation(fields: [payrollCycleId], references: [id], onDelete: Cascade)
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeSalary EmployeeSalary? @relation(fields: [employeeSalaryId], references: [id], onDelete: SetNull)

  @@map("payslips")
}

enum PayslipStatus {
  DRAFT
  GENERATED
  SENT
  PAID
  HOLD

  @@map("payslip_status")
}

enum PaymentMethod {
