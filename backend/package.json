{
  "name": "hrms-backend",
  "version": "1.0.0",
  "description": "HRMS Portal 2026 - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "kill-port": "npx --yes kill-port 5000 5001",
    "dev": "npm run kill-port && nodemon --exec \"ts-node -r tsconfig-paths/register\" src/server.ts",
    "dev:direct": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "create:super-admin": "ts-node src/scripts/create-super-admin.ts",
    "upgrade:role": "ts-node src/scripts/upgrade-user-role.ts",
    "test:rbac": "ts-node src/scripts/test-rbac.ts",
    "test:super-admin": "ts-node src/scripts/test-super-admin-access.ts",
    "verify:phase2": "ts-node src/scripts/verify-phase2-rbac.ts",
    "seed:permissions": "ts-node src/scripts/seed-permissions.ts",
    "seed:leave": "ts-node src/scripts/seed-leave-data.ts",
    "seed:attendance": "ts-node src/scripts/seed-attendance-data.ts",
    "test:leave": "ts-node src/scripts/test-leave-management.ts",
    "test:all": "ts-node src/scripts/test-all-modules-phase3.ts",
    "test:payroll": "ts-node -r tsconfig-paths/register src/scripts/test-payroll-module.ts",
    "test:phase4": "ts-node -r tsconfig-paths/register src/scripts/test-phase4-modules.ts",
    "seed:payroll": "ts-node -r tsconfig-paths/register src/scripts/seed-payroll-data.ts",
    "mark:december": "ts-node -r tsconfig-paths/register src/scripts/mark-december-present.ts",
    "assign:salary": "ts-node -r tsconfig-paths/register src/scripts/assign-salary-to-mani-saravanan.ts",
    "migrate:sub-department": "ts-node -r tsconfig-paths/register src/scripts/run-sub-department-migration.ts",
    "seed:dept-subdept": "ts-node -r tsconfig-paths/register src/scripts/seed-department-subdepartment.ts",
    "seed:bnc-motors-depts": "ts-node -r tsconfig-paths/register src/scripts/seed-bnc-motors-departments.ts",
    "seed:bnc-motors-positions": "ts-node -r tsconfig-paths/register src/scripts/seed-bnc-motors-positions.ts",
    "seed:org-and-logins": "ts-node -r tsconfig-paths/register src/scripts/seed-organization-and-logins.ts",
    "migrate:workflow-mapping": "ts-node -r tsconfig-paths/register src/scripts/apply-workflow-mapping-migration.ts",
    "migrate:rule-setting": "ts-node -r tsconfig-paths/register src/scripts/apply-rule-setting-migration.ts",
    "migrate:rule-setting-event-rules": "ts-node -r tsconfig-paths/register src/scripts/add-rule-setting-event-rules-columns.ts",
    "migrate:auto-credit-setting": "ts-node -r tsconfig-paths/register src/scripts/apply-auto-credit-setting-migration.ts",
    "migrate:auto-credit-rule": "ts-node -r tsconfig-paths/register src/scripts/add-auto-credit-rule-columns.ts",
    "migrate:event-balance-entry-dates": "ts-node -r tsconfig-paths/register src/scripts/add-event-balance-entry-date-range-columns.ts",
    "ensure:login": "ts-node -r tsconfig-paths/register src/scripts/ensure-login-users.ts",
    "test:iclock": "ts-node -r tsconfig-paths/register src/scripts/test-iclock-local.ts",
    "check:attendance-log": "ts-node -r tsconfig-paths/register src/scripts/check-latest-attendance-log.ts",
    "fix:shift-constraint": "ts-node -r tsconfig-paths/register src/scripts/fix-shift-code-constraint.ts",
    "find:unmapped-leave-components": "ts-node -r tsconfig-paths/register src/scripts/find-unmapped-leave-components.ts",
    "map:unmapped-leave-components": "ts-node -r tsconfig-paths/register src/scripts/map-unmapped-leave-components.ts",
    "clear:hardcoded-leave-entitlements": "ts-node -r tsconfig-paths/register src/scripts/clear-hardcoded-leave-entitlements.ts",
    "fix:employee-approval-in-workflows": "ts-node -r tsconfig-paths/register src/scripts/fix-employee-approval-in-workflow-mappings.ts",
    "migrate:face-encoding": "ts-node -r tsconfig-paths/register src/scripts/add-face-encoding-column.ts",
    "test:lop": "ts-node -r tsconfig-paths/register src/scripts/test-lop-calculation.ts",
    "check:saravanan": "ts-node -r tsconfig-paths/register src/scripts/check-saravanan-attendance-summary.ts",
    "set:lop-unpaid": "ts-node -r tsconfig-paths/register src/scripts/set-lop-leave-type-unpaid.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "hrms",
    "hr",
    "payroll",
    "ats",
    "recruitment"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/pdfkit": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.17.2",
    "redis": "^4.6.12",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "axios": "^1.13.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^5.8.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
