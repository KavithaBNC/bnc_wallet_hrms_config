# Server Configuration
NODE_ENV=development
# Use 5001 to match root "npm run dev" and frontend proxy; use 5000 if running backend only
PORT=5001
BASE_URL=http://localhost:5001

# CORS
CORS_ORIGIN=http://localhost:3000

# Database (add ?connection_limit=20&pool_timeout=30 if you see "Timed out fetching a new connection from the connection pool")
DATABASE_URL=postgresql://postgres:password@localhost:5432/hrms_db_backup?connection_limit=20&pool_timeout=30

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Email Configuration
EMAIL_FROM=noreply@hrms.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Frontend URL
FRONTEND_URL=http://localhost:3000

# eSSL Biometric / eSSL Cloud API (attendance sync)
# Leave empty to disable. Employee codes in eSSL must match HRMS Employee.employeeCode.
ESSL_CLOUD_API_URL=
ESSL_CLOUD_API_KEY=
# Optional: override attendance logs path (default: /api/attendance/logs)
# ESSL_CLOUD_ATTENDANCE_ENDPOINT=/api/attendance/logs
