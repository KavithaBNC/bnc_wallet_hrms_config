# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hrms_live

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server - 5001 matches root "npm run dev" and frontend proxy
PORT=5001
NODE_ENV=development
BASE_URL=http://localhost:5001

# CORS - frontend origin
CORS_ORIGIN=http://localhost:3000

# Configurator API (auth, modules)
CONFIGURATOR_API_URL=https://bnc-ai.com/ragapi


# Optional overrides
# CONFIGURATOR_DEFAULT_ROLE=ORG_ADMIN
# CONFIGURATOR_PLACEHOLDER_PASSWORD_HASH=$2b$10$...
# CONFIGURATOR_ROLE_IDS={"ORG_ADMIN":31,"HR_MANAGER":30,"MANAGER":29,"EMPLOYEE":28}

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Email
# EMAIL_FROM=noreply@hrms.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# AWS S3 / MinIO
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# eSSL Biometric
# ESSL_CLOUD_API_URL=
# ESSL_CLOUD_API_KEY=
